<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView android:id="@+id/ttl_none" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:text="No expiry" />
    <TextView android:id="@+id/ttl_5m" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:text="5 min" />
    <TextView android:id="@+id/ttl_1h" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:text="1 hour" />
    <TextView android:id="@+id/ttl_24h" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:text="24 hours" />
    <TextView android:id="@+id/ttl_read" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:text="On read" />
</LinearLayout>
